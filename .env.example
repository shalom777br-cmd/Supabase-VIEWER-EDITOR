# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VIEWER_PASSWORD: The administrator password for entering the admin viewer panel session (defaults to "admin" if empty).
VIEWER_PASSWORD="your_admin_password_here"

# SUPABASE_URL: The base URL of your Supabase project (e.g. https://xxxxxxxxxxxxxxxx.supabase.co).
SUPABASE_URL="your_supabase_url_here"

# SUPABASE_SERVICE_ROLE_KEY: The secret Supabase service role key used server-side to bypass RLS and perform operations.
# NEVER expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"
